{
  "name": "@novasphere/ui-bento",
  "version": "0.0.1",
  "description": "Bento Grid layout system. Contains BentoGrid, BentoCard, and the data-driven layout engine. Includes drag-to-reorder via Framer Motion.",
  "license": "MIT",
  "author": "novasphere contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/novasphere",
    "directory": "packages/ui-bento"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && cp src/BentoCard/BentoCard.module.css dist/",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6003",
    "storybook:build": "storybook build"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*",
    "framer-motion": "*"
  },
  "dependencies": {
    "@novasphere/tokens": "workspace:*",
    "@novasphere/ui-glass": "workspace:*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.0",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.0.0",
    "typescript": "~5.6.0",
    "vitest": "^2.1.8"
  }
}
