{
  "name": "@novasphere/agent-core",
  "version": "0.0.1",
  "description": "The AI adapter system. Framework-agnostic TypeScript — no React, no CSS, no UI. Contains the AgentAdapter interface, adapter factory, and concrete adapter implementations.",
  "license": "MIT",
  "author": "novasphere contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/novasphere",
    "directory": "packages/agent-core"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@mlc-ai/web-llm": "*",
    "@anthropic-ai/sdk": "*",
    "openai": "*"
  },
  "peerDependenciesMeta": {
    "@mlc-ai/web-llm": { "optional": true },
    "@anthropic-ai/sdk": { "optional": true },
    "openai": { "optional": true }
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "~5.6.0",
    "vitest": "^2.1.8"
  }
}
