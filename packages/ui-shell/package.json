{
  "name": "@novasphere/ui-shell",
  "version": "0.0.1",
  "sideEffects": false,
  "description": "Application shell components. The structural frame of the dashboard: Sidebar, Topbar, AppShell, NavItem, and BreadcrumbBar. Tenant-aware.",
  "license": "MIT",
  "author": "novasphere contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/novasphere",
    "directory": "packages/ui-shell"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && cp src/AppShell/AppShell.module.css dist/ && cp src/NavItem/NavItem.module.css dist/ && cp src/Sidebar/Sidebar.module.css dist/ && cp src/Topbar/Topbar.module.css dist/ && cp src/BreadcrumbBar/BreadcrumbBar.module.css dist/",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6007",
    "storybook:build": "storybook build"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "framer-motion": "*",
    "lucide-react": "*",
    "zustand": "*"
  },
  "dependencies": {
    "@novasphere/tenant-core": "workspace:*",
    "@novasphere/tokens": "workspace:*",
    "@novasphere/ui-auth": "workspace:*",
    "@novasphere/ui-glass": "workspace:*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.0",
    "tsup": "^8.0.0",
    "typescript": "~5.6.0",
    "tailwindcss": "^4.2.0",
    "vitest": "^2.1.8"
  }
}
