# =============================================================================
# Novasphere Demo — Environment variables (Section 10)
# Copy to .env.local and set values. Never commit .env.local.
# =============================================================================

# ── App ─────────────────────────────────────────────────────────────────────
# Base URL (e.g. http://localhost:3000)
# NEXT_PUBLIC_APP_URL=

# mock | api  (default: mock)
# NEXT_PUBLIC_DATA_SOURCE=

# static | dynamic  (default: static)
# NEXT_PUBLIC_TENANT_MODE=

# ── AI Adapter ──────────────────────────────────────────────────────────────
# auto | ollama | webllm | claude | openai | mock — default: auto (factory resolves priority chain)
# NEXT_PUBLIC_AI_ADAPTER=

# ── Local LLM — Ollama ──────────────────────────────────────────────────────
# default: http://localhost:11434
# OLLAMA_BASE_URL=

# default: qwen2.5:0.5b
# OLLAMA_MODEL=

# default: 2000
# OLLAMA_TIMEOUT_MS=

# ── External AI (server-side only — never NEXT_PUBLIC_) ─────────────────────
# Activates ClaudeAdapter
# ANTHROPIC_API_KEY=

# default: claude-3-5-haiku-20241022
# ANTHROPIC_MODEL=

# Activates OpenAIAdapter (if no Anthropic key)
# OPENAI_API_KEY=

# default: gpt-4o-mini
# OPENAI_MODEL=

# Custom base URL for OpenAI-compatible APIs
# OPENAI_BASE_URL=

# ── Security ────────────────────────────────────────────────────────────────
# Max agent requests/min per IP (default: 20)
# RATE_LIMIT_AGENT_RPM=
