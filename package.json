{
  "name": "novasphere",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "description": "AI-native SaaS dashboard template — Liquid Glass, Bento Grid, agent copilot",
  "scripts": {
    "clean": "rm -rf node_modules .turbo playwright-report test-results && pnpm -r exec -- sh -c 'rm -rf node_modules dist .next 2>/dev/null || true' && rm -rf apps/demo/.next",
    "clean:install": "pnpm clean && pnpm install",
    "dev": "turbo dev --filter=demo",
    "dev:legacy": "pnpm --filter demo dev",
    "dev:watch": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "ESLINT_USE_FLAT_CONFIG=false turbo lint",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6002",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "tailwindcss": "^4.2.0",
    "turbo": "^2.3.0",
    "@changesets/cli": "^2.27.10",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint": "^8.57.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "storybook": "^8.6.18"
  }
}
