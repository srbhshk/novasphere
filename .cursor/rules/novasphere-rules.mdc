---
alwaysApply: true
---

# =============================================================================
# NOVASPHERE — CURSOR RULES
# =============================================================================
# Project   : novasphere
# Version   : 0.3.0
# License   : MIT
# Description: An open-source, AI-native SaaS dashboard template featuring
#              Liquid Glass aesthetics, Generative UI, Bento Grid layouts,
#              and a pluggable agent copilot. Structured as a pnpm workspace
#              monorepo with independently publishable packages. Each package
#              is usable standalone — install only what you need.
#              AI-independent by default: runs fully offline via Ollama
#              (Qwen2.5 0.5B). External providers (Claude, OpenAI) are
#              opt-in via env keys. No API key required to run or demo.
# Repo      : https://github.com/your-org/novasphere
# =============================================================================
#
# PURPOSE OF THIS FILE
# --------------------
# This file is the single source of truth for Cursor AI when working on
# novasphere. It defines the architecture, conventions, constraints, and
# patterns that MUST be followed at all times.
#
# Cursor must NEVER:
#   - Invent patterns not described here
#   - Add dependencies not listed in the approved stack
#   - Make assumptions about business logic — ask instead
#   - Skip TypeScript types or use `any`
#   - Generate placeholder/lorem content in production code paths
#   - Combine concerns that this file separates (e.g. data fetching in UI)
#   - Import across package boundaries that are forbidden (see Section 3)
#   - Create files outside the structure defined in Section 4
#
# When in doubt: STOP and ask the developer. Do not guess.
# =============================================================================


# =============================================================================
# 1. PROJECT IDENTITY
# =============================================================================

project:
  name: novasphere
  type: pnpm workspace monorepo — open-source template + independently
        publishable UI packages
  license: MIT
  npm_scope: "@novasphere"

  description: >
    An open-source, AI-native SaaS dashboard template featuring Liquid Glass
    aesthetics, Generative UI that adapts in real-time, immersive Bento Grid
    layouts, and a pluggable agent copilot (Copilot Panel). Structured as a
    pnpm workspace monorepo with independently publishable packages under the
    @novasphere npm scope. The demo app proves everything works together.
    Each package is usable in isolation — teams pick only what they need.
    Runs fully offline by default using Ollama + Qwen2.5 0.5B. No API key,
    no internet connection required to run, develop, or demo.

  north_star: >
    Demo-first. Must impress in 5 seconds. Must be forkable and runnable in
    under 10 minutes. Individual packages must be installable into an existing
    app in under 30 minutes. Internals may be complex — developer experience
    must never be.

  non_goals:
    - Not a full application — it is a template and composable package library
    - Not a full Micro Frontend (no separate deployments, no module federation)
    - Not a design system replacing shadcn/ui — it extends it
    - Not a backend — server logic lives only in Next.js API routes in apps/demo
    - Not coupled to any AI provider
    - Not a model training or fine-tuning framework
    - Not a monolith — shared logic must live in packages, not duplicated in apps


# =============================================================================
# 2. MONOREPO ARCHITECTURE
# =============================================================================
# This is the most important section. Read it fully before writing any code.
# The monorepo structure, package registry, and boundary rules are FIXED.
# Cursor must not create new packages without explicit developer approval.
# =============================================================================

monorepo:
  tool: pnpm workspaces
  root_config: pnpm-workspace.yaml
  node_version: ">=20.0.0"
  package_manager: pnpm

  workspace_pattern: |
    packages:
      - "apps/*"
      - "packages/*"

  # ── PACKAGE REGISTRY ────────────────────────────────────────────────────────
  # Every package in the monorepo is listed here with its full identity.
  # Cursor must use these EXACT names in import statements and package.json.
  # ─────────────────────────────────────────────────────────────────────────────

  packages:

    # ── APPS ──────────────────────────────────────────────────────────────────

    "apps/demo":
      npm_name: null                    # Not published to npm — demo only
      description: >
        The full novasphere demo application. A Next.js 16 App Router app
        that imports and composes all packages. This is what you deploy to
        Vercel to demo. It is NOT a template to fork — it is proof that all
        packages work together. Teams fork individual packages, not this app.
      depends_on:
        - "@novasphere/tokens"
        - "@novasphere/ui-glass"
        - "@novasphere/ui-bento"
        - "@novasphere/ui-shell"
        - "@novasphere/ui-charts"
        - "@novasphere/ui-agent"
        - "@novasphere/ui-auth"
        - "@novasphere/agent-core"
        - "@novasphere/tenant-core"
      framework: Next.js 16 (App Router)
      deploys_to: Vercel

    # ── FOUNDATION PACKAGES (no UI, no React) ─────────────────────────────────

    "@novasphere/tokens":
      path: packages/tokens
      description: >
        Design token foundation. CSS custom properties and a Tailwind CSS
        preset. Zero JavaScript. Zero React. Zero dependencies.
        Every other package that needs design tokens imports ONLY this package.
        This is the single source of truth for all visual constants.
      exports:
        - tailwind.preset.ts     # Tailwind preset — import in tailwind.config.ts
        - tokens.css             # CSS custom properties — import in globals.css
        - index.ts               # Re-exports token constants as typed TS values
      depends_on: []             # ZERO dependencies — this is the foundation
      peer_deps: []
      publishes_to_npm: true

    "@novasphere/agent-core":
      path: packages/agent-core
      description: >
        The AI adapter system. Framework-agnostic TypeScript — no React, no CSS,
        no UI. Contains the AgentAdapter interface, adapter factory, all concrete
        adapter implementations (Ollama, WebLLM, Claude, OpenAI, Mock), prompt
        templates, and AgentContext types. Any framework can use this package.
      exports:
        - adapter.interface.ts
        - adapter.factory.ts
        - context.types.ts
        - prompts.ts
        - adapters/ollama.adapter.ts
        - adapters/webllm.adapter.ts
        - adapters/claude.adapter.ts
        - adapters/openai.adapter.ts
        - adapters/mock.adapter.ts
      depends_on: []             # ZERO UI dependencies
      peer_deps:
        - "@mlc-ai/web-llm"      # optional — only if webllm adapter used
        - "@anthropic-ai/sdk"    # optional — only if claude adapter used
        - "openai"               # optional — only if openai adapter used
      publishes_to_npm: true

    "@novasphere/tenant-core":
      path: packages/tenant-core
      description: >
        The multi-tenancy system. Framework-agnostic TypeScript — no React,
        no CSS. Contains TenantConfig types, the static tenant registry,
        and tenant resolution utilities. Used by Next.js middleware in apps/demo
        and importable into any framework's server layer.
      exports:
        - tenant.types.ts
        - tenant.registry.ts
        - tenant.resolver.ts
      depends_on: []             # ZERO dependencies
      peer_deps: []
      publishes_to_npm: true

    # ── UI PACKAGES (React components) ────────────────────────────────────────

    "@novasphere/ui-glass":
      path: packages/ui-glass
      description: >
        Liquid Glass component system. The core visual aesthetic of novasphere.
        Contains GlassCard, GlassPanel, GlassModal, the ambient background
        layer, and the grain overlay. This is the most foundational UI package
        — all other UI packages depend on it for visual consistency.
        Self-contained: install this alone to get the Liquid Glass aesthetic
        in any React app.
      exports:
        - GlassCard
        - GlassPanel
        - GlassModal
        - AmbientBackground
        - GrainOverlay
      depends_on:
        - "@novasphere/tokens"
      peer_deps:
        - react
        - react-dom
      publishes_to_npm: true

    "@novasphere/ui-bento":
      path: packages/ui-bento
      description: >
        Bento Grid layout system. Contains BentoGrid, BentoCard, and the
        data-driven layout engine. The grid reads a BentoLayoutConfig[] array
        and renders cards accordingly. Includes drag-to-reorder via Framer
        Motion. This is the Generative UI mechanism — the AI agent restructures
        the dashboard by emitting a new layout config array.
      exports:
        - BentoGrid
        - BentoCard
        - BentoSpan
        - bento.types.ts         # BentoLayoutConfig, BentoCardConfig types
      depends_on:
        - "@novasphere/tokens"
        - "@novasphere/ui-glass"
      peer_deps:
        - react
        - react-dom
        - framer-motion
      publishes_to_npm: true

    "@novasphere/ui-charts":
      path: packages/ui-charts
      description: >
        Chart component wrappers. Glass-styled Recharts components: SparklineChart,
        DonutChart, AreaChart, HeatmapChart. Each accepts typed data props and
        handles loading/empty/error states internally. Responsive by default.
      exports:
        - SparklineChart
        - DonutChart
        - AreaChart
        - HeatmapChart
        - chart.types.ts         # Typed data shapes for each chart
      depends_on:
        - "@novasphere/tokens"
        - "@novasphere/ui-glass"
      peer_deps:
        - react
        - react-dom
        - recharts
      publishes_to_npm: true

    "@novasphere/ui-agent":
      path: packages/ui-agent
      description: >
        Copilot Panel UI. The visual layer of the agent system. Contains
        CopilotPanel, AgentMessage, SuggestionChips, TypingIndicator,
        AdapterStatusBadge, and AdapterInfoPopover. This package knows
        NOTHING about which AI is running — it communicates only through
        the AgentAdapter interface from @novasphere/agent-core.
        Install this with agent-core to get a fully working AI copilot.
      exports:
        - CopilotPanel
        - AgentMessage
        - SuggestionChips
        - TypingIndicator
        - AdapterStatusBadge
        - AdapterInfoPopover
      depends_on:
        - "@novasphere/tokens"
        - "@novasphere/ui-glass"
        - "@novasphere/agent-core"
      peer_deps:
        - react
        - react-dom
        - framer-motion
        - zustand
      publishes_to_npm: true

    "@novasphere/ui-auth":
      path: packages/ui-auth
      description: >
        Authentication UI components. Provider-agnostic — the UI is decoupled
        from the auth implementation. Contains LoginForm, SignupForm,
        ForgotPasswordForm, UserMenu, AuthGuard, and TenantSwitcher.
        The actual auth provider (Clerk, NextAuth, Supabase Auth, etc.)
        is injected via an AuthAdapter interface defined in this package.
        Teams wire their own auth behind the interface — the UI never changes.
      exports:
        - LoginForm
        - SignupForm
        - ForgotPasswordForm
        - UserMenu
        - AuthGuard
        - TenantSwitcher
        - auth.adapter.interface.ts   # The contract auth providers must implement
        - auth.types.ts
      depends_on:
        - "@novasphere/tokens"
        - "@novasphere/ui-glass"
        - "@novasphere/tenant-core"
      peer_deps:
        - react
        - react-dom
        - react-hook-form
        - zod
      publishes_to_npm: true

    "@novasphere/ui-shell":
      path: packages/ui-shell
      description: >
        Application shell components. The structural frame of the dashboard:
        Sidebar, Topbar, AppShell, NavItem, and BreadcrumbBar.
        Tenant-aware — reads from TenantConfig to render tenant name, logo,
        and navigation items. This is the outermost UI layer — it wraps all
        other packages.
      exports:
        - AppShell
        - Sidebar
        - Topbar
        - NavItem
        - BreadcrumbBar
      depends_on:
        - "@novasphere/tokens"
        - "@novasphere/ui-glass"
        - "@novasphere/tenant-core"
        - "@novasphere/ui-auth"
      peer_deps:
        - react
        - react-dom
        - framer-motion
        - zustand
      publishes_to_npm: true


  # ── PACKAGE BOUNDARY RULES ───────────────────────────────────────────────────
  # These are HARD RULES. Cursor must check these before every import.
  # A boundary violation is a blocking error — fix it before moving on.
  # ─────────────────────────────────────────────────────────────────────────────

  boundary_rules:

    foundation_law: >
      The dependency graph must be a strict DAG (Directed Acyclic Graph).
      No circular dependencies between packages — ever.
      The allowed dependency directions are:
        apps/* → any package
        ui-shell → ui-glass, ui-auth, tenant-core, tokens
        ui-auth → ui-glass, tenant-core, tokens
        ui-agent → ui-glass, agent-core, tokens
        ui-bento → ui-glass, tokens
        ui-charts → ui-glass, tokens
        ui-glass → tokens
        agent-core → nothing (no UI packages)
        tenant-core → nothing (no UI packages)
        tokens → nothing

    explicit_violations:
      # Cursor must REFUSE to write these imports. They are always wrong.
      - "agent-core must NEVER import from any ui-* package"
      - "tenant-core must NEVER import from any ui-* package"
      - "tokens must NEVER import from any other package"
      - "ui-glass must NEVER import from ui-bento, ui-agent, ui-auth, ui-shell, ui-charts"
      - "ui-bento must NEVER import from ui-agent, ui-auth, ui-shell"
      - "ui-charts must NEVER import from ui-agent, ui-auth, ui-shell, ui-bento"
      - "ui-auth must NEVER import from ui-agent, ui-shell, ui-bento, ui-charts"
      - "ui-agent must NEVER import from ui-auth, ui-shell, ui-bento, ui-charts"
      - "apps/demo must NEVER contain logic that belongs in a package"
      - "No package may import directly from apps/demo"

    cross_package_import_format: >
      When one package imports from another, always import from the package
      name, never from a relative path that crosses the package boundary.

      CORRECT:   import { GlassCard } from '@novasphere/ui-glass'
      INCORRECT: import { GlassCard } from '../../ui-glass/src/GlassCard'

    internal_import_format: >
      Within a package, always use relative imports.

      CORRECT:   import { tokens } from '../tokens'
      INCORRECT: import { tokens } from '@novasphere/ui-glass/tokens'
                 (this is self-referential and wrong)


# =============================================================================
# 3. APPROVED TECH STACK
# =============================================================================
# Cursor must NEVER introduce a library outside this list without explicit
# developer approval. If a task requires something not listed here, STOP
# and ask before proceeding.
# =============================================================================

stack:
  framework:
    name: Next.js 16
    scope: apps/demo only
    router: App Router (NOT Pages Router — never use pages/)
    rendering: >
      Prefer React Server Components (RSC) by default.
      Use `"use client"` only when the component requires:
        - useState / useReducer / useEffect
        - Browser APIs (window, document, navigator)
        - Event handlers
        - Framer Motion animations
        - Zustand store access
      Never add `"use client"` to layout.tsx or page.tsx unless absolutely
      required. Push client boundaries as deep into the tree as possible.
      Packages do NOT use Next.js — they are framework-agnostic React.

  language:
    name: TypeScript
    version: "5.x"
    mode: strict
    tsconfig_strategy: >
      Root tsconfig.json defines base settings.
      Each package and app extends it via tsconfig.json with
      "extends": "../../tsconfig.base.json".
      Path aliases are defined per-package — never globally across packages.
    rules:
      - NO `any` — ever. Use `unknown` and narrow it.
      - NO `as` type assertions without a comment explaining why it is safe.
      - NO implicit return types on exported functions — always annotate.
      - Prefer `type` over `interface` for object shapes unless extending.
      - Use `interface` only when a class implements it.
      - Enums are forbidden — use `as const` objects instead.
      - All props must be typed via a named `type` exported from the same file.
      - Each package's public API is defined in its index.ts — only what is
        exported from index.ts is considered the public API.

  styling:
    primary: Tailwind CSS v4
    modules: CSS Modules (for glass effects, keyframes, ambient layers)
    tailwind_strategy: >
      @novasphere/tokens exports design tokens and a Tailwind preset.
      The demo app uses Tailwind 4 CSS-first config: @import "tailwindcss"
      in apps/demo/src/styles/globals.css, with @theme for token mapping.
      UI packages (ui-bento, ui-glass, etc.) use Tailwind utilities but
      live outside the app. The app must register them via @source so
      Tailwind scans packages/ui-*/src/** for class names. See globals.css
      @source "../../../../packages/ui-*/src/**/*.{ts,tsx,js,jsx}".
    rules:
      - Design tokens live ONLY in packages/tokens. Never defined elsewhere.
      - Liquid Glass effects (backdrop-filter, gradients, grain) live in CSS
        Modules co-located with their component. File: ComponentName.module.css
      - Never use inline style={{}} for values expressible as CSS vars or Tailwind.
      - Never use styled-components, Emotion, or any CSS-in-JS runtime library.
      - Tailwind classes never built by string concatenation — use cn() always.
      - Dark mode is the default. No light-mode-only colour values.

  components:
    base: shadcn/ui (Radix UI primitives)
    shadcn_strategy: >
      shadcn/ui components are installed into packages/ui-glass/src/ui/
      (not apps/demo). This means the base components are part of the
      published package, not the app. Any package that needs a shadcn
      primitive wraps the one in ui-glass — it never re-installs shadcn.
    rules:
      - shadcn source files in src/ui/ are NEVER modified. Extend by wrapping.
      - Component files export exactly ONE primary component as default export.
      - Props types are named [ComponentName]Props and exported from index.ts.
      - Never build a custom component for something shadcn/ui already provides.
      - Every custom component has a Storybook story in its own package.

  state:
    library: Zustand
    version: "4.x"
    scope_rules: >
      Zustand stores are NOT inside packages — they live in apps/demo/src/store/.
      Packages are stateless — they receive state via props or context.
      Exception: ui-agent may use a local Zustand store for conversation
      history scoped to the CopilotPanel — but it must be exported as a
      hook (useAgentStore) so the consuming app can access it if needed.
    stores:
      "apps/demo/src/store/layout.store.ts":
        purpose: Bento grid layout config (BentoLayoutConfig[] array)
      "apps/demo/src/store/agent.store.ts":
        purpose: Copilot conversation, agent status, download progress
      "apps/demo/src/store/tenant.store.ts":
        purpose: Current tenant config, feature flags, theme overrides
    rules:
      - One store file per domain slice.
      - Stores export a typed hook: use[Domain]Store.
      - Never put derived values in the store — use selectors.
      - Server state (API data) is NEVER in Zustand — use TanStack Query.

  data_fetching:
    library: TanStack Query (React Query)
    version: "5.x"
    scope: apps/demo/src/hooks/ only
    rules:
      - All server data fetching goes through TanStack Query hooks.
      - Hooks named use[Resource][Action].ts (e.g. useMetricsList.ts).
      - Every hook handles loading, error, and empty states explicitly.
      - Never fetch data directly in a component body.
      - API routes live in apps/demo/src/app/api/.
      - Mock responses live in apps/demo/src/mocks/.
      - Mock/real switch controlled by NEXT_PUBLIC_DATA_SOURCE env var.
      - Packages never use TanStack Query — they are data-agnostic.
        Data is passed into package components via props.

  charts:
    library: Recharts
    version: "2.x"
    scope: "@novasphere/ui-charts package"
    rules:
      - Recharts is a dependency of ui-charts only — not the demo app directly.
      - All chart components wrapped in typed components in ui-charts.
      - Charts accept typed data props — never raw API shapes.
      - Charts use ResponsiveContainer by default.
      - Chart colours reference @novasphere/tokens, never hardcoded hex.
      - Every chart has a loading skeleton variant.

  animation:
    library: Framer Motion
    version: "11.x"
    scope: ui-bento, ui-agent, ui-shell (peer dependency in each)
    rules:
      - Framer Motion used ONLY for:
          - Bento card drag-to-reorder (ui-bento)
          - CopilotPanel slide-in/out (ui-agent)
          - Page transitions (apps/demo)
          - Component enter/exit (ui-shell)
      - CSS animations (keyframes in CSS Modules) used for:
          - Ambient background shifts (ui-glass)
          - Pulse indicators (ui-glass)
          - Skeleton shimmer (ui-glass)
          - Typing indicator bounces (ui-agent)
      - All Framer Motion variants defined as constants in a variants.ts
        file within each package — never inline in JSX.
      - Never use Framer Motion where a CSS animation suffices.

  ai_adapter:
    pattern: Adapter Pattern (interface + concrete implementations)
    scope: "@novasphere/agent-core package exclusively"
    interface_file: packages/agent-core/src/adapter.interface.ts
    factory_file: packages/agent-core/src/adapter.factory.ts

    resolution_order: |
      The factory resolves the active adapter in this EXACT priority order.
      It evaluates top-to-bottom and uses the first successful match.

        1. OllamaAdapter   — DEFAULT. Health ping to OLLAMA_BASE_URL on init.
                             Model: qwen2.5:0.5b (Q4, ~400MB, CPU-capable).
                             Works offline, zero config, fastest responses.

        2. WebLLMAdapter   — BROWSER FALLBACK. Used when Ollama unreachable
                             AND NEXT_PUBLIC_AI_ADAPTER is 'auto' or unset.
                             Model: Phi-3-mini-4k-instruct-q4f16_1-MLC.
                             Requires WebGPU (Chrome 113+). ~2GB IndexedDB cache.
                             If navigator.gpu undefined → fall to MockAdapter.

        3. ClaudeAdapter   — EXTERNAL OPT-IN. Activated by ANTHROPIC_API_KEY.
                             Server-side only. Never exposes key to client.
                             Streams via apps/demo/src/app/api/agent/route.ts.

        4. OpenAIAdapter   — EXTERNAL OPT-IN. Activated by OPENAI_API_KEY
                             when ANTHROPIC_API_KEY is absent.
                             Same server-side-only pattern as Claude.

        5. MockAdapter     — FALLBACK / CI / TESTING. Always works.
                             Reads from apps/demo/src/mocks/agent-responses.mock.ts
                             with configurable artificial delay. No network calls.

    local_llm:
      primary:
        runtime: Ollama
        model: qwen2.5:0.5b
        rationale: >
          Qwen2.5 0.5B is optimal for novasphere's agent task profile:
          structured reasoning, JSON output, intent classification, and
          short summarisation. These are instruction-following tasks, not
          creative generation — a 0.5B model is sufficient. ~400MB Q4
          quantized. Runs on CPU. 50–200ms response latency.
        alternatives:
          - qwen2.5:1.5b     # better reasoning, 3× larger
          - phi3:mini        # Microsoft alternative, similar size
          - llama3.2:1b      # Meta alternative
        api: OpenAI-compatible REST at OLLAMA_BASE_URL/v1
        health_endpoint: GET OLLAMA_BASE_URL/api/tags
        timeout_ms: 2000

      browser_fallback:
        runtime: WebLLM
        package: "@mlc-ai/web-llm"
        model: Phi-3-mini-4k-instruct-q4f16_1-MLC
        import_strategy: >
          Dynamic import only inside webllm.adapter.ts.
          Never at top-level — it is heavy and must be code-split.
          import('@mlc-ai/web-llm') inside an async init() method.
        webgpu_check: >
          Always check typeof navigator !== 'undefined' && 'gpu' in navigator
          before attempting WebLLM init. If false, skip to MockAdapter.

    agent_tasks: >
      The agent performs ONLY these structured tasks. Prompts are designed
      for JSON or short deterministic text output — not open-ended generation.
      All prompts are defined in packages/agent-core/src/prompts.ts.
      Never write prompts inline in adapters or components.

      Task types:
        layout_restructure  — Returns BentoLayoutConfig[] JSON
        intent_classify     — Returns one of N predefined intent strings
        anomaly_summarise   — Returns 1–2 sentence plain text
        action_suggest      — Returns SuggestionChip[] JSON
        metric_explain      — Returns short plain text explanation

    agent_context:
      type_file: packages/agent-core/src/context.types.ts
      shape: |
        type AgentContext = {
          tenantId       : string
          userId         : string
          currentRoute   : string
          visibleCards   : BentoCardConfig[]
          activeMetrics  : MetricSnapshot[]
          recentActivity : ActivityEvent[]
          userMessage    : string
        }
      assembly: >
        Assembled by useAgentContext() hook in apps/demo before each send.
        Serialised into prompt string for Ollama/WebLLM.
        Sent as structured data for Claude/OpenAI via API route.

    adapter_rules:
      - AgentAdapter interface is the ONLY contract ui-agent touches.
      - ui-agent never imports a concrete adapter — only the factory output.
      - All AI calls are non-blocking. UI never freezes waiting for response.
      - Every adapter implements: chat(), streamChat(), getStatus(), destroy().
      - All adapters return AgentResponse type — never adapter-specific shapes.
      - Prompts live in prompts.ts only — never inline in adapters.
      - Adding a provider: implement AgentAdapter, register in factory,
        add env var to .env.example, document in CONTRIBUTING.md.
        No other files change.

  local_llm_packages:
    ollama: built-in REST client — no extra npm package needed
    webllm:
      package: "@mlc-ai/web-llm"
      version: "0.2.x"
      scope: packages/agent-core (optional peer dep)

  icons:
    library: Lucide React
    rules:
      - Lucide React only. No other icon library.
      - Import individually: `import { ChevronDown } from 'lucide-react'`
      - Each package that uses icons lists lucide-react as a peer dependency.

  forms:
    libraries: React Hook Form + Zod
    scope: "@novasphere/ui-auth package"
    rules:
      - All forms use React Hook Form with zodResolver.
      - Zod schemas in packages/ui-auth/src/schemas/ named [resource].schema.ts
      - Never use uncontrolled inputs outside React Hook Form.

  testing:
    libraries:
      - Vitest (unit tests — package-level)
      - React Testing Library (component tests — package-level)
      - Playwright (E2E tests — apps/demo level)
      - Storybook (interaction tests + visual — per package)
    rules:
      - See Section 8 for full testing rules.

  build:
    package_bundler: tsup
    rationale: >
      tsup (esbuild-based) builds each package to CJS + ESM dual output.
      Fast, minimal config, tree-shakeable output. Each package has its own
      tsup.config.ts. The demo app uses Next.js's built-in bundler.
    output_formats: ["cjs", "esm"]
    declaration_files: true
    source_maps: true

  versioning:
    tool: Changesets (@changesets/cli)
    rationale: >
      Changesets manages independent versioning of each package.
      When a PR changes ui-glass and agent-core, each gets its own
      version bump and changelog entry. The demo app is not versioned
      (it is not published). Changesets integrates with GitHub Actions
      for automated npm releases.
    config_file: .changeset/config.json
    rules:
      - Every PR that changes a package includes a changeset file.
      - Run `pnpm changeset` to create one. Cursor must remind developers.
      - Version bumps follow semver strictly.
      - Breaking changes in any package require a major version bump.

  package_manager: pnpm
  node_version: ">=20.0.0"


