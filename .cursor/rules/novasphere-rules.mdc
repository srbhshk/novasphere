# =============================================================================
# 5. NAMING CONVENTIONS
# =============================================================================

naming:
  files:
    components: "PascalCase — ComponentName.tsx"
    stories: "PascalCase — ComponentName.stories.tsx"
    tests: "PascalCase — ComponentName.test.tsx"
    css_modules: "PascalCase — ComponentName.module.css"
    hooks: "camelCase — useResourceAction.ts"
    stores: "camelCase — domain.store.ts"
    types: "camelCase — domain.types.ts"
    schemas: "camelCase — resource.schema.ts"
    utils: "camelCase — utilityName.ts"
    api_routes: "always route.ts (Next.js App Router convention)"
    mocks: "camelCase — resource.mock.ts"
    adapters: "camelCase — provider.adapter.ts"
    barrel_exports: "always index.ts"

  typescript:
    components: PascalCase
    types: PascalCase
    props_type: "[ComponentName]Props"
    hooks: "use[Resource][Action]"
    store_hooks: "use[Domain]Store"
    constants: SCREAMING_SNAKE_CASE
    enums: "FORBIDDEN — use `as const` objects"
    zod_schemas: "camelCase + Schema suffix (e.g. loginFormSchema)"
    api_response_types: "PascalCase + Response suffix (e.g. MetricsResponse)"
    event_handlers: "handle[Event] prefix (e.g. handleSubmit)"
    adapter_interfaces: "[Provider]Adapter (e.g. AgentAdapter, AuthAdapter)"

  packages:
    npm_scope: "@novasphere"
    directory_name: "kebab-case matching npm name without scope
                     (e.g. @novasphere/ui-glass → packages/ui-glass)"

  css:
    module_classes: "camelCase (e.g. .glassCard, .ambientLayer)"
    css_variables: "--ns-[category]-[property] (e.g. --ns-color-accent)"
    keyframes: "camelCase (e.g. @keyframes ambientShift)"

  git:
    branches: "[type]/[scope]/[short-description]
               (e.g. feat/ui-glass/ambient-animation,
                     fix/agent-core/ollama-timeout,
                     chore/tokens/add-blur-tokens)"
    commits: "Conventional Commits — see Section 9"


# =============================================================================
# 6. COMPONENT RULES
# =============================================================================

components:
  structure: |
    Every component folder contains exactly:
      ComponentName.tsx          — implementation
      ComponentName.module.css   — styles (only if glass/animation effects)
      ComponentName.stories.tsx  — Storybook stories (REQUIRED)
      ComponentName.test.tsx     — RTL tests (REQUIRED)
      index.ts                   — barrel: export default + export type Props

  file_header_template: |
    // SPDX-License-Identifier: MIT
    // @novasphere/[package-name] — ComponentName
    // [one-line description of what this component does and nothing more]

  component_template: |
    "use client" // DELETE this line if component does not need client features

    import type { ComponentNameProps } from './ComponentName'
    // other imports — package imports before relative imports

    export type ComponentNameProps = {
      // ALL props explicitly typed — no untyped or implicit props
      // optional props must have default values defined in destructuring
    }

    export default function ComponentName({
      prop1,
      prop2 = 'default',
    }: ComponentNameProps): JSX.Element {
      // implementation
    }

  rules:
    - Components are pure and presentational by default. All logic in hooks.
    - No component may exceed 200 lines. Split into sub-components if needed.
    - No component may have more than 8 props. Use a config object if needed.
    - No component imports from another component's internal files —
      only from its index.ts barrel export.
    - Leaf components do not access Zustand stores directly. Props only.
      Store access is allowed only in panel-level and page-level components.
    - No hardcoded user-facing strings. All copy passed as props or from
      a copy object in the same package.
    - Every interactive element has aria-label or visible label text.
    - No click handlers on non-interactive HTML elements.
    - children typed as React.ReactNode always.
    - Loading and error states are mandatory for async data components.
    - "use client" is deleted from the file if not needed — never left in.


# =============================================================================
# 7. PACKAGE.JSON RULES
# =============================================================================
# Each package has a package.json. Cursor must follow this template exactly.
# =============================================================================

package_json:
  template: |
    {
      "name": "@novasphere/[package-name]",
      "version": "0.0.1",
      "description": "[one sentence from package registry in Section 2]",
      "license": "MIT",
      "author": "novasphere contributors",
      "repository": {
        "type": "git",
        "url": "https://github.com/your-org/novasphere",
        "directory": "packages/[package-name]"
      },
      "main": "./dist/index.cjs",
      "module": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "exports": {
        ".": {
          "import": "./dist/index.js",
          "require": "./dist/index.cjs",
          "types": "./dist/index.d.ts"
        }
      },
      "files": ["dist"],
      "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src --max-warnings 0",
        "test": "vitest run",
        "test:watch": "vitest",
        "storybook": "storybook dev -p [PORT]",
        "storybook:build": "storybook build"
      },
      "peerDependencies": {},    // framework deps go here (react, framer-motion)
      "dependencies": {},        // only @novasphere/* internal deps go here
      "devDependencies": {}      // build tools, test libs, storybook
    }

  rules:
    - peerDependencies contains React, React DOM, and any framework library
      the package uses but does not bundle (framer-motion, recharts, zustand).
    - dependencies contains only other @novasphere/* packages.
    - devDependencies contains tsup, TypeScript, Vitest, RTL, Storybook.
    - Never put a peerDependency also in dependencies — it will be bundled twice.
    - The "files" field must only include "dist" — never ship src to npm.
    - Storybook port numbers: tokens=6001, ui-glass=6002, ui-bento=6003,
      ui-charts=6004, ui-agent=6005, ui-auth=6006, ui-shell=6007.


# =============================================================================
# 8. TESTING RULES
# =============================================================================

testing:
  philosophy: >
    Test behaviour, not implementation. Tests describe what a user or system
    experiences — not internal state or function names. If a test breaks when
    you rename a variable but the UI is unchanged, the test is wrong.

  unit_and_component_tests:
    tools: Vitest + React Testing Library
    location: "[package]/src/ComponentName/ComponentName.test.tsx"
    rules:
      - Every component in every package requires a test file.
      - Tests cover: renders without crash, correct output given props,
        interactive states (click/focus/keyboard), loading state, error state,
        empty state.
      - Use screen.getByRole over getByTestId wherever semantics allow.
      - Never test Tailwind class names or CSS properties — test visible output.
      - Never mock Zustand stores — use real store instances with test data.
      - Mock only: network calls (use msw), timers, random values.
      - Use userEvent over fireEvent for all user interactions.
      - Each package runs tests independently: `pnpm --filter @novasphere/ui-glass test`

  e2e_tests:
    tool: Playwright
    location: tests/e2e/
    naming: feature-name.spec.ts
    scope: Runs against apps/demo only
    critical_journeys:
      - Dashboard loads with mock data and all bento cards render
      - Copilot panel opens, message sent, response rendered
      - Agent dispatches layout change, bento grid reorders
      - Tenant config changes theme tokens correctly
      - Auth forms render and validate (mock auth)
      - Adapter status badge shows correct engine
      - WebGPU unavailable degrades gracefully to Mock
    rules:
      - Page Object Model required for flows with 3+ steps.
      - Never use fixed timeouts — always await elements or network idle.
      - Run against MockAdapter only in CI — no real API keys in CI.
      - Playwright accessibility checks run on every page test.

  storybook:
    location: "[package]/src/ComponentName/ComponentName.stories.tsx"
    rules:
      - Every component has a Default story with all required props.
      - Every significant prop variant has its own named story.
      - Glass components render on dark background (default).
      - Interaction tests (@storybook/test) required for:
          CopilotPanel (send message flow)
          BentoCard (drag interaction)
          LoginForm (submit + validation)
          Any component with internal state transitions
      - Stories use mock data from the package's own src/mocks/ or
        from @novasphere/agent-core mocks — never inline fake data.

  coverage:
    minimum: 80% per package for components
    enforcement: CI fails below threshold per package


# =============================================================================
# 9. GIT & CONTRIBUTION RULES
# =============================================================================

git:
  strategy: GitHub Flow (main + feature branches)
  main_branch: main
  rules:
    - main is always deployable and always passes CI.
    - All work on feature branches cut from main.
    - Branch format: [type]/[package-scope]/[short-description]
        feat/ui-glass/grain-overlay
        fix/agent-core/ollama-timeout-handling
        chore/tokens/add-shadow-tokens
        docs/root/update-contributing
    - Branches deleted after merge.
    - No force pushes to main — ever.
    - Squash merge only — one clean commit per feature lands on main.

  commits:
    spec: Conventional Commits v1.0.0
    format: "[type]([scope]): [short imperative description]"
    scopes:
      tokens        : design token package
      ui-glass      : Liquid Glass components
      ui-bento      : Bento Grid system
      ui-charts     : chart components
      ui-agent      : Copilot Panel UI
      ui-auth       : auth UI components
      ui-shell      : app shell components
      agent-core    : AI adapter system
      tenant-core   : tenancy system
      demo          : apps/demo changes
      e2e           : Playwright tests
      ci            : GitHub Actions workflows
      dx            : developer experience / tooling
      deps          : dependency updates
      changeset     : changeset file additions
    examples:
      - "feat(ui-bento): add drag-to-reorder with Framer Motion"
      - "fix(agent-core): handle Ollama 2s timeout gracefully"
      - "feat(ui-auth): add TenantSwitcher component"
      - "chore(deps): update @mlc-ai/web-llm to 0.2.4"
      - "feat(agent-core)!: change AgentAdapter interface — streamChat signature"
    rules:
      - Imperative mood, lowercase, no trailing period.
      - Breaking changes: add "!" after scope.
      - 72 char max in subject line.
      - PR that changes a package MUST also include a changeset file.
        Run `pnpm changeset` and commit the generated file.

  pull_requests:
    rules:
      - Description explains the WHY, not the what.
      - References a GitHub issue: "Closes #N"
      - CI must pass (lint + typecheck + tests + build) before merge.
      - PR title follows Conventional Commits format.
      - Changeset file included for any package change.


# =============================================================================
# 10. ENVIRONMENT VARIABLES
# =============================================================================

env:
  location: apps/demo/.env.example (all vars documented here)
  rules:
    - .env.local is git-ignored. Never committed.
    - Client vars prefixed NEXT_PUBLIC_ only.
    - Secret vars (API keys) NEVER prefixed NEXT_PUBLIC_.
    - All vars validated at startup via Zod in apps/demo/src/lib/env.ts.
      App fails fast with a clear error message if required vars are missing.
    - Packages never read env vars directly — they receive config via props
      or constructor arguments from the app layer.

  variables: |
    # ── App ──────────────────────────────────────────────────────────────
    NEXT_PUBLIC_APP_URL         # Base URL (e.g. http://localhost:3000)
    NEXT_PUBLIC_DATA_SOURCE     # mock | api  (default: mock)
    NEXT_PUBLIC_TENANT_MODE     # static | dynamic  (default: static)

    # ── AI Adapter ───────────────────────────────────────────────────────
    NEXT_PUBLIC_AI_ADAPTER      # auto|ollama|webllm|claude|openai|mock
                                # default: auto (factory resolves priority chain)

    # ── Local LLM — Ollama ───────────────────────────────────────────────
    OLLAMA_BASE_URL             # default: http://localhost:11434
    OLLAMA_MODEL                # default: qwen2.5:0.5b
    OLLAMA_TIMEOUT_MS           # default: 2000

    # ── External AI (server-side only — never NEXT_PUBLIC_) ──────────────
    ANTHROPIC_API_KEY           # Activates ClaudeAdapter
    ANTHROPIC_MODEL             # default: claude-3-5-haiku-20241022
    OPENAI_API_KEY              # Activates OpenAIAdapter (if no Anthropic key)
    OPENAI_MODEL                # default: gpt-4o-mini
    OPENAI_BASE_URL             # Custom base URL for OpenAI-compatible APIs

    # ── Security ─────────────────────────────────────────────────────────
    RATE_LIMIT_AGENT_RPM        # Max agent requests/min per IP (default: 20)


# =============================================================================
# 11. LOCAL LLM UX RULES
# =============================================================================

local_llm_ux:
  adapter_status_badge:
    component: packages/ui-agent/src/AdapterStatusBadge/
    location_in_ui: CopilotPanel header — always visible
    states:
      checking    : "Detecting AI engine…"
      ollama      : "● Local · Qwen2.5 0.5B"      # green dot
      webllm      : "● Browser · Phi-3 Mini"        # blue dot
      downloading : "↓ Loading model [XX%]"
      claude      : "● Claude"                      # purple dot
      openai      : "● GPT"                         # teal dot
      mock        : "◌ Demo mode"                   # muted
    click_action: >
      Opens AdapterInfoPopover explaining what is running and how to change.
      This is the primary discoverability surface for the adapter system.
    rules:
      - Always visible — never hidden. Transparency is a core value.
      - Status sourced from agent store's adapterStatus field.
      - Never shows an error — always shows a state.

  ollama_not_running:
    behaviour: >
      Silently falls through to WebLLMAdapter. Shows one-time dismissible
      banner in CopilotPanel: "Ollama not detected — running in browser mode.
      Install Ollama for faster responses." with link to https://ollama.com
    rules:
      - Never block the UI. Health check is async and non-blocking.
      - Panel loads immediately in 'checking' state.
      - Banner is dismissible and never shown again after dismissed (localStorage).

  webllm_first_load:
    behaviour: >
      Shows download progress bar in CopilotPanel body:
        - Percentage + MB downloaded / total MB
        - Estimated time remaining
        - "One-time download — instant on next load" note
      Copilot input disabled during download. Rest of dashboard fully usable.
    store_field: agent.store.ts → downloadProgress: number (0–100)
    rules:
      - Progress from WebLLM's initProgressCallback only — never estimated.
      - Animate to 100% then fade out on completion.
      - Only shown for WebLLMAdapter — never for other adapters.


# =============================================================================
# 12. API ROUTE RULES
# =============================================================================

api:
  location: apps/demo/src/app/api/
  rules:
    - Export only named HTTP method handlers: GET, POST, PUT, DELETE.
    - Validate all request bodies with Zod before processing.
    - Consistent response shape:
        success: { data: T, error: null }
        failure: { data: null, error: { code: string, message: string } }
    - Never return raw data shapes — always map to a typed response type.
    - API routes never import from packages' internal src/ — only from index.ts.
    - Auth check at the top of every protected route.
    - Never log API keys, tokens, or PII.
    - Semantically correct HTTP status codes always.
    - Rate limiting on /api/agent route via RATE_LIMIT_AGENT_RPM.


# =============================================================================
# 13. PERFORMANCE RULES
# =============================================================================

performance:
  rules:
    - Images: next/image always. Never raw <img> in apps/demo.
    - Fonts: next/font with self-hosted files in apps/demo/public/fonts/.
    - Icons: import individually from lucide-react. Never the barrel import.
    - Heavy components use dynamic() with { ssr: false }:
        CopilotPanel, all chart components, AdapterInfoPopover.
    - WebLLM adapter uses dynamic import inside async init() — never top-level.
    - Glass layers: max 3 stacked in any viewport region. More = perf review.
    - Continuous animations (ambient, pulse, shimmer) in CSS keyframes.
      Discrete interactions in Framer Motion.
    - Each package is built with tsup tree-shaking enabled.
    - Bundle budget: no single package's dist exceeds 50KB gzipped (excl. assets).
    - Run `pnpm --filter apps/demo analyze` before every demo release.


# =============================================================================
# 14. ACCESSIBILITY RULES
# =============================================================================

accessibility:
  standard: WCAG 2.1 AA
  rules:
    - All interactive elements keyboard navigable.
    - Focus rings visible — never `outline: none` without custom focus style.
    - Colour contrast: 4.5:1 for text, 3:1 for UI components.
    - Images: meaningful alt text or aria-hidden="true" if decorative.
    - All CSS animations wrapped in @media (prefers-reduced-motion: no-preference).
    - CopilotPanel fully keyboard accessible: open, type, send, close, dismiss.
    - Bento grid logical tab order matches visual order.
    - shadcn/ui ARIA attributes are never overridden.
    - Playwright accessibility checks run on every E2E page test.


# =============================================================================
# 15. SECURITY RULES
# =============================================================================

security:
  rules:
    - No secrets in client-side code, packages, or git history — ever.
    - External URLs validated before use — no open redirect vulnerabilities.
    - Tenant ID from request always validated server-side in API routes.
      Never trust a client-provided tenant ID without server verification.
    - CSP headers configured in apps/demo/next.config.ts.
    - `pnpm audit` run before every release. Failing audit blocks release.
    - dangerouslySetInnerHTML never used without DOMPurify sanitisation.
    - Rate limiting on /api/agent to prevent AI cost abuse.
    - Packages never read process.env — env config passed from app layer only.


# =============================================================================
# 16. DOCUMENTATION RULES
# =============================================================================

documentation:
  rules:
    - Every exported function, type, hook, component has a JSDoc comment.
    - JSDoc format:
        /**
         * [What it does — one sentence maximum]
         *
         * @param propName - [what it is]
         * @returns [what comes back]
         * @example
         * <ComponentName prop="value" />
         */
    - Each package has its own README.md covering:
        - What it is (one paragraph)
        - Installation (npm install command)
        - Basic usage example
        - Link to Storybook
        - List of exports
    - Root README.md covers: what novasphere is, monorepo structure,
      quick start (pnpm install + pnpm dev), and links to each package.
    - CONTRIBUTING.md covers: setup, branching, commit format, changesets,
      testing, adding a new adapter, adding a new component, adding a package.
    - CHANGELOG.md auto-generated by Changesets on release.
    - nova.config.ts heavily commented — first config file a developer reads.
    - TODO comments require a linked GitHub issue: // TODO(#123): description


# =============================================================================
# 17. CURSOR BEHAVIOURAL RULES
# =============================================================================

cursor_behaviour:
  before_writing_code:
    - Identify which package the task belongs to using Section 2 registry.
    - Confirm the file location matches Section 4 structure exactly.
    - Confirm naming matches Section 5.
    - Check boundary rules in Section 2 — is this import allowed?
    - If task requires a library not in Section 3 — STOP and ask.
    - If task is ambiguous about which package it belongs in — STOP and ask.
    - If task would create a new package — STOP and ask.

  while_writing_code:
    - Never generate placeholder content in production code paths.
      Mocks live in apps/demo/src/mocks/ or within the package's own test files.
    - Never add console.log. Use error boundaries and structured logging.
    - Never skip TypeScript types to make something compile faster.
    - Never hardcode a design value — add the token to @novasphere/tokens first.
    - Never write a prompt inline — add it to agent-core/src/prompts.ts.
    - Write the test in the same session as the component. Never defer.
    - Add a changeset after changing any publishable package.

  when_uncertain:
    - Do NOT guess at business logic, data shapes, or user-facing copy.
    - Do NOT choose between two architectural approaches silently.
    - Do NOT assume a boundary is safe without checking Section 2 explicitly.
    - State the assumption and ask for confirmation before proceeding.

  never_do:
    - Never use the Pages Router (pages/ directory) anywhere.
    - Never use `any` in TypeScript anywhere.
    - Never install a dependency without adding it to this file first.
    - Never import across a forbidden package boundary (Section 2).
    - Never put logic in apps/demo that belongs in a package.
    - Never put a Zustand store inside a package (except ui-agent's local store).
    - Never hardcode tenant-specific data anywhere.
    - Never commit API keys, even in comments or examples.
    - Never create a CSS variable outside @novasphere/tokens.
    - Never modify files in any package's src/ui/ (shadcn source).
    - Never skip a Storybook story for a new component.
    - Never push directly to main.
    - Never publish a package without a changeset.


# =============================================================================
# 18. NOVA.CONFIG.TS — TOP-LEVEL PROJECT CONFIG
# =============================================================================
# Lives at the monorepo root. Future target for the novasphere CLI.
# This is what a CLI wizard would generate. All top-level values live here.
# =============================================================================

nova_config:
  location: nova.config.ts (monorepo root)
  shape: |
    // nova.config.ts
    // This file is the top-level configuration for novasphere.
    // Future versions of the novasphere CLI will generate this file.
    // Change values here to customise the demo app and package defaults.

    export const novaConfig = {
      project: {
        name: 'novasphere',
        version: '0.1.0',
      },
      theme: {
        accentColor:  '#4f8ef7',   // primary brand colour
        accentColor2: '#a78bfa',   // secondary
        accentColor3: '#34d399',   // success / positive
        glassBlur:    'md',        // 'sm' | 'md' | 'lg'
        borderRadius: 'lg',        // 'sm' | 'md' | 'lg' | 'xl'
        darkMode:     true,        // false = light mode default
      },
      agent: {
        adapter:           'auto',        // 'auto'|'ollama'|'webllm'|'claude'|'openai'|'mock'
        name:              'Nova',        // display name of the copilot
        avatarEmoji:       '🤖',
        ollamaModel:       'qwen2.5:0.5b',
        showAdapterStatus: true,          // show engine badge in CopilotPanel
      },
      tenant: {
        mode:            'static',        // 'static' | 'dynamic'
        defaultTenantId: 'demo',
      },
      features: {
        bentoReorder:      true,   // drag-to-reorder bento cards
        generativeLayout:  true,   // agent can restructure layout
        multiTenant:       false,  // tenant switching UI
        authEnabled:       false,  // show auth UI in demo
      },
    } as const

    export type NovaConfig = typeof novaConfig

  rules:
    - nova.config.ts is the ONLY place top-level values are defined.
    - Components and packages read config via the useNovaConfig() hook
      in apps/demo — they never import nova.config.ts directly.
    - Packages accept config values as props — they are never hardwired
      to nova.config.ts. The app layer reads config and passes it down.
    - Adding a feature flag: add to nova.config.ts, add to NovaConfig type,
      add a Storybook story variant, document in README.

